# BulkSeq Studio workflow: reference-based bulk RNA-seq, STAR -> featureCounts ->
# DESeq2 -> figures, following the bundled protocol. Globals and helper functions
# are defined BEFORE the rule includes so included rules can reference them.
import os
import re
import pandas as pd

configfile: "config/config.yaml"


# ---------------------------------------------------------------------------
# Samples
# ---------------------------------------------------------------------------
samples_df = pd.read_csv(config["input"]["samples"], sep="\t", dtype=str).fillna("")
samples_df = samples_df.set_index("sample_id", drop=False)
SAMPLES = samples_df["sample_id"].tolist()
# Fail fast on an empty sample sheet rather than crashing deep in a rule.
if not SAMPLES:
    raise ValueError(
        f"Sample sheet '{config['input']['samples']}' has no sample rows. "
        "Add at least one sample (Input Data tab) before running."
    )
FIRST_SAMPLE = SAMPLES[0]

# Constrain {sample} to known IDs so paired (..._1.trim) and single (...trim)
# trimmed filenames parse unambiguously.
if SAMPLES:
    wildcard_constraints:
        sample="|".join(re.escape(s) for s in SAMPLES)


def sample_layout(sample):
    layout = str(samples_df.loc[sample, "layout"]).lower() if "layout" in samples_df.columns else "paired"
    return "single" if layout == "single" else "paired"


def is_paired(sample):
    return sample_layout(sample) == "paired"


ALL_PAIRED = all(is_paired(s) for s in SAMPLES) if SAMPLES else True


def raw_fastq(sample, read):
    column = "fastq_1" if read == 1 else "fastq_2"
    value = str(samples_df.loc[sample, column]) if column in samples_df.columns else ""
    return value


# Map each downloadable raw FASTQ target to its ENA URL (built from samples.tsv).
URL_BY_TARGET = {}
for _s in SAMPLES:
    for _url_col, _path_col in (("fastq_1_url", "fastq_1"), ("fastq_2_url", "fastq_2")):
        if _url_col in samples_df.columns and _path_col in samples_df.columns:
            _url = str(samples_df.loc[_s, _url_col]).strip()
            _target = str(samples_df.loc[_s, _path_col]).strip()
            if _url and _target:
                URL_BY_TARGET[_target] = _url


def trimmed_fastqs(sample):
    if is_paired(sample):
        return [f"results/trimmed/{sample}_1.trim.fastq.gz", f"results/trimmed/{sample}_2.trim.fastq.gz"]
    return [f"results/trimmed/{sample}.trim.fastq.gz"]


# Reads handed to the aligner/quantifier, as a source chain:
#   raw -> (fastp trimming?) -> (rRNA filtering?) -> aligner.
# TRIMMING and RRNA_FILTER (defined below) are read at rule-eval time. Paired-end only
# (single-end is rejected up front). _reads_pre_rrna is also the input to sortmerna.
def _reads_pre_rrna(sample, read):
    # After optional trimming, before optional rRNA filtering. Single-end trimmed reads
    # drop the _{read} tag (there is only one file).
    if TRIMMING:
        if is_paired(sample):
            return f"results/trimmed/{sample}_{read}.trim.fastq.gz"
        return f"results/trimmed/{sample}.trim.fastq.gz"
    return raw_fastq(sample, read)


def rrna_filtered_fastqs(sample):
    if is_paired(sample):
        return [f"results/rrna_filtered/{sample}_1.fastq.gz", f"results/rrna_filtered/{sample}_2.fastq.gz"]
    return [f"results/rrna_filtered/{sample}.fastq.gz"]


def aligner_read(sample, read):
    if RRNA_FILTER:
        if is_paired(sample):
            return f"results/rrna_filtered/{sample}_{read}.fastq.gz"
        return f"results/rrna_filtered/{sample}.fastq.gz"
    return _reads_pre_rrna(sample, read)


def aligner_fastqs(sample):
    if is_paired(sample):
        return [aligner_read(sample, 1), aligner_read(sample, 2)]
    return [aligner_read(sample, 1)]


# ---------------------------------------------------------------------------
# Reference / resources
# ---------------------------------------------------------------------------
REF = config.get("reference", {})
WF = config.get("workflow", {})
INPUT = config.get("input", {})
# Count-matrix mode: the user supplies a counts table, so the pipeline skips
# download/QC/alignment/featureCounts and ingests it into results/counts/counts.txt.
COUNT_MATRIX_MODE = INPUT.get("type") == "count_matrix"
COUNT_MATRIX = INPUT.get("count_matrix")
# Microarray mode: GEO/GSE intensities ingested via GEOquery/affy and analyzed
# with limma; no alignment/reference/counts. limma emits the DESeq2-shaped
# artifacts so figures/enrichment/GOI are shared.
MICROARRAY_MODE = INPUT.get("type") == "microarray"
# DESeq2-results mode: the user supplies a ready DESeq2 results table, so the pipeline
# skips download/QC/alignment/featureCounts/DESeq2 and ingests it into the canonical
# results/deseq2/deseq2_results.csv, then runs enrichment/figures/PPI. Outputs that need
# raw/normalized counts (PCA, sample correlation, count heatmaps, GOI) are gated off.
DE_RESULTS_MODE = INPUT.get("type") == "deseq2_results"
DE_RESULTS_TABLE = INPUT.get("deseq2_results")
# Differential-expression engine (count-based routes only). DESeq2 is the default;
# limma-voom is an opt-in cross-check that consumes the same counts.txt and emits the
# same canonical artifacts (results CSV, up/down, deseq2_objects.rds, normalized,
# checks 08/09), minus the DESeq2-specific TOST equivalence test. Not applicable to
# microarray (limma-trend) or deseq2-results (no counts) modes.
DE_ENGINE = WF.get("de_engine") or "DESeq2"
_VALID_DE_ENGINES = ("DESeq2", "limma-voom", "edgeR")
if DE_ENGINE not in _VALID_DE_ENGINES:
    raise ValueError(
        f"workflow.de_engine '{DE_ENGINE}' is invalid. Allowed: {', '.join(_VALID_DE_ENGINES)}."
    )
VOOM_MODE = DE_ENGINE == "limma-voom" and not (MICROARRAY_MODE or DE_RESULTS_MODE)
EDGER_MODE = DE_ENGINE == "edgeR" and not (MICROARRAY_MODE or DE_RESULTS_MODE)
# Alternative count-based DE engines (limma-voom, edgeR) skip the DESeq2-specific TOST
# equivalence test, so unchanged_genes / check 13 are gated off for both.
ALT_DE_MODE = VOOM_MODE or EDGER_MODE
# Aligner / quantifier (fastq/sra modes only). STAR or HISAT2 -> sorted BAM -> featureCounts;
# Salmon -> transcript-level quantification -> tximport (no BAM). All three converge on the
# canonical results/counts/counts.txt so DESeq2 and the whole downstream are identical.
ALIGNER = (WF.get("aligner") or "STAR").upper()
USE_HISAT2 = ALIGNER == "HISAT2"
USE_SALMON = ALIGNER == "SALMON"
# rRNA filtering (SortMeRNA): drop ribosomal RNA reads after trimming, before alignment.
# Only meaningful on the fastq/sra alignment routes (count-matrix / microarray /
# deseq2-results carry no reads). The default rRNA reference is downloaded to RRNA_DB and
# indexed once into RRNA_IDX, which every per-sample sortmerna job then shares read-only.
SORTMERNA = config.get("sortmerna", {})
RRNA_FILTER = (
    bool(WF.get("rrna_filtering", False))
    and not (COUNT_MATRIX_MODE or MICROARRAY_MODE or DE_RESULTS_MODE)
)
# rRNA filtering tool. SortMeRNA (reference-based, default, needs the rRNA db + index) or
# RiboDetector (reference-free ML, no db download). Both emit the same
# results/rrna_filtered/{sample}_{1,2}.fastq.gz so the aligner input is identical.
RRNA_TOOL = (WF.get("rrna_tool") or "sortmerna").lower()
_VALID_RRNA_TOOLS = ("sortmerna", "ribodetector")
if RRNA_TOOL not in _VALID_RRNA_TOOLS:
    raise ValueError(
        f"workflow.rrna_tool '{RRNA_TOOL}' is invalid. Allowed: {', '.join(_VALID_RRNA_TOOLS)}."
    )
# Contamination screening (FastQ Screen): optional QC, off by default. Aligns a read subsample
# against a panel of reference genomes and reports the % hitting each — a QC report, NOT a
# filter (reads are not removed). fastq/sra route only; the genome panel is fetched on demand.
CONTAM_SCREEN = (
    bool(WF.get("contamination_screen", False))
    and not (COUNT_MATRIX_MODE or MICROARRAY_MODE or DE_RESULTS_MODE)
)
RRNA_DB = "references/rrna_db.fasta"
RRNA_IDX = "references/rrna_idx"
# fastp trimming toggle. When off, raw reads go straight to the rRNA filter / aligner
# (fastp is skipped entirely). FastQC-pre / FastQC-post gate their own QC steps; post-trim
# FastQC only makes sense when trimming actually runs. All only on the fastq/sra route.
TRIMMING = (
    bool(WF.get("trimming", True))
    and not (COUNT_MATRIX_MODE or MICROARRAY_MODE or DE_RESULTS_MODE)
)
# Trimmer choice (fastq/sra route). fastp is the default; Trim Galore and Trimmomatic are
# opt-in. All three emit results/trimmed/{sample}_{1,2}.trim.fastq.gz, so the downstream is
# identical and the default (fastp) path is byte-for-byte unchanged.
TRIMMER = (WF.get("trimmer") or "fastp").lower()
_VALID_TRIMMERS = ("fastp", "trim-galore", "trimmomatic")
if TRIMMER not in _VALID_TRIMMERS:
    raise ValueError(
        f"workflow.trimmer '{TRIMMER}' is invalid. Allowed: {', '.join(_VALID_TRIMMERS)}."
    )
FASTQC_PRE = (
    bool(WF.get("fastqc_pre_trim", True))
    and not (COUNT_MATRIX_MODE or MICROARRAY_MODE or DE_RESULTS_MODE)
)
FASTQC_POST = bool(WF.get("fastqc_post_trim", True)) and TRIMMING
# Quantifier: how reads are summarised to gene counts on the STAR/HISAT2 (BAM) routes.
# Salmon's route is fixed (tximport); featureCounts is the default; STAR can also reuse its
# own --quantMode GeneCounts table (STAR_GeneCounts). All routes converge on the canonical
# results/counts/counts.txt, so DESeq2 and the whole downstream are unchanged.
_VALID_QUANTIFIERS = {
    "STAR": ("featureCounts", "STAR_GeneCounts"),
    "HISAT2": ("featureCounts",),
    "SALMON": ("Salmon_tximport",),
}
if USE_SALMON:
    QUANTIFIER = "Salmon_tximport"
else:
    QUANTIFIER = WF.get("quantifier") or "featureCounts"
if not (COUNT_MATRIX_MODE or MICROARRAY_MODE or DE_RESULTS_MODE):
    _allowed_q = _VALID_QUANTIFIERS.get(ALIGNER, ("featureCounts",))
    if QUANTIFIER not in _allowed_q:
        raise ValueError(
            f"quantifier '{QUANTIFIER}' is not valid with aligner '{ALIGNER}'. "
            f"Allowed for {ALIGNER}: {', '.join(_allowed_q)}."
        )
USE_STAR_GENECOUNTS = (
    QUANTIFIER == "STAR_GeneCounts" and ALIGNER == "STAR"
    and not (COUNT_MATRIX_MODE or MICROARRAY_MODE or DE_RESULTS_MODE)
)
# Single-end and paired-end are both supported on the alignment route, but a run must be
# homogeneous: one rule can't emit both a 1-file and a 2-file trimmed output, so mixed layouts
# are rejected with guidance. Count-matrix / microarray / deseq2-results modes have no layout.
if not (COUNT_MATRIX_MODE or MICROARRAY_MODE or DE_RESULTS_MODE):
    _paired_samples = [s for s in SAMPLES if is_paired(s)]
    _single_samples = [s for s in SAMPLES if not is_paired(s)]
    if _paired_samples and _single_samples:
        raise ValueError(
            "Mixed paired-end and single-end samples in one run are not supported. "
            f"Paired: {', '.join(_paired_samples[:3])}; single: {', '.join(_single_samples[:3])}. "
            "Split them into two projects (one per layout)."
        )
# True when every sample is single-end (fastq/sra route only). Selects the single-end rule
# variants; STAR / featureCounts / strandedness inference are already layout-aware.
SINGLE_END = (
    not (COUNT_MATRIX_MODE or MICROARRAY_MODE or DE_RESULTS_MODE)
    and bool(SAMPLES) and all(not is_paired(s) for s in SAMPLES)
)
# Mitochondrial + chloroplast (organellar) gene handling: keep | discard | separate.
# Only meaningful on the alignment routes (they have a genome + GTF to identify organellar
# contigs). When not "keep", featureCounts/Salmon write counts.raw.txt and filter_organellar
# produces the canonical counts.txt (nuclear-only; plus the organellar subset in "separate"
# mode). "keep" leaves the counts flow exactly as before.
ORGANELLAR_MODE = (WF.get("organellar_genes") or "keep").lower()
ORGANELLAR_FILTER = (
    ORGANELLAR_MODE in ("discard", "separate")
    and not (COUNT_MATRIX_MODE or MICROARRAY_MODE or DE_RESULTS_MODE)
)
# GSVA sample-level pathway activity: organism-safe (runs only on the user's custom gene sets,
# never a bundled human collection). RSeQC extended alignment QC needs a genome BAM (no Salmon).
GSVA_ON = (
    bool(WF.get("gsva", False))
    and bool(config.get("gene_sets", {}).get("custom_gene_sets"))
    and not DE_RESULTS_MODE  # needs the normalized expression matrix
)
RSEQC_ON = (
    bool(WF.get("rseqc", False))
    and not (COUNT_MATRIX_MODE or MICROARRAY_MODE or DE_RESULTS_MODE)
    and not USE_SALMON
)
COUNTS_FILE = "results/counts/counts.txt"
COUNTS_RAW = "results/counts/counts.raw.txt" if ORGANELLAR_FILTER else COUNTS_FILE
# featureCounts auto-names its summary <output>.summary, so the quantification summary
# tracks the counts file name. It reflects read counting (pre-organellar-filter), which
# is what the 07 check and MultiQC report.
COUNTS_SUMMARY = COUNTS_RAW + ".summary"

GENOME_FA = "references/genome.fa"
ANNOTATION_GTF = "references/annotation.gtf"
STAR_INDEX = "references/star_index"
HISAT2_INDEX_DIR = "references/hisat2_index"
HISAT2_INDEX = "references/hisat2_index/genome"  # bowtie/hisat2 index prefix
TRANSCRIPTOME_FA = "references/transcripts.fa"
SALMON_INDEX = "references/salmon_index"


def rule_threads(name, default=4):
    return int(config.get("rule_threads", {}).get(name, default))


def rule_mem_mb(name, default=8):
    return int(config.get("rule_memory_gb", {}).get(name, default)) * 1000


# ---------------------------------------------------------------------------
# Rule includes (order matters only for readability; globals already defined)
# ---------------------------------------------------------------------------
include: "rules/sra.smk"
include: "rules/reference.smk"
include: "rules/qc.smk"
include: "rules/trimming.smk"
include: "rules/rrna.smk"
include: "rules/alignment.smk"
include: "rules/quantification.smk"
include: "rules/microarray.smk"
include: "rules/deseq2.smk"
include: "rules/figures.smk"
include: "rules/enrichment.smk"
include: "rules/checks.smk"
include: "rules/reports.smk"
include: "rules/coexpression.smk"
include: "rules/stats.smk"
include: "rules/ppi.smk"


# ---------------------------------------------------------------------------
# Targets
# ---------------------------------------------------------------------------
def final_targets():
    targets = [
        "results/deseq2/deseq2_results.csv",
        "results/export/ranked_genes.rnk",
        "results/figures/set_overlap_dotplot.png",
        "results/figures/set_overlap_dotplot.svg",
        "results/stats/set_overlap.csv",
        "results/reports/run_summary.txt",
        "results/reports/timing_summary.txt",
        "results/reports/software_versions.txt",
        "results/reports/results_report.html",
        "checks/sanity_checks.txt",
    ]
    # Per-sample / normalized-count outputs: every mode produces them EXCEPT
    # deseq2-results (a results table carries no per-sample expression matrix).
    if not DE_RESULTS_MODE:
        targets += [
            "results/export/normalized_expression_matrix.csv",
            "results/figures/sample_correlation_pearson.png",
            "results/figures/sample_correlation_pearson.svg",
            "results/figures/sample_correlation_spearman.png",
            "results/figures/sample_correlation_spearman.svg",
            "results/export/sample_correlation_pearson.csv",
            "results/export/sample_correlation_spearman.csv",
            "results/figures/wilcoxon_concordance.png",
            "results/figures/wilcoxon_concordance.svg",
            "results/stats/wilcoxon_results.csv",
        ]
    # Microarray has no counts.txt (intensities, not counts); deseq2-results has no
    # counts at all; every other mode does.
    if not (MICROARRAY_MODE or DE_RESULTS_MODE):
        targets.insert(0, "results/counts/counts.txt")
        # The DESeq2-specific TOST equivalence output is not produced by voom / edgeR.
        if not ALT_DE_MODE:
            targets.append("results/deseq2/unchanged_genes.csv")
    if not (COUNT_MATRIX_MODE or MICROARRAY_MODE or DE_RESULTS_MODE):
        # MultiQC aggregates FastQC/fastp/STAR — irrelevant without alignment.
        targets.insert(0, "results/qc/multiqc/multiqc_report.html")
    if WF.get("figures", True):
        # deseq2-results mode can draw only the results-table figures; PCA / sample
        # distance / top-DEG heatmap need the counts/vst and degrade to placeholders.
        fig_list = ("ma_plot", "volcano", "pvalue_histogram") if DE_RESULTS_MODE else \
                   ("pca", "sample_distance", "ma_plot", "volcano", "top_deg_heatmap")
        for fig in fig_list:
            targets.append(f"results/figures/{fig}.png")
            targets.append(f"results/figures/{fig}.svg")
    if WF.get("enrichment", True):
        targets.append("results/enrichment/enrichment_summary.txt")
        targets.append("results/enrichment/kegg_ora.csv")
        targets.append("results/enrichment/kegg_gsea.csv")
        for fig in ("enrichment_dotplot", "enrichment_gsea", "enrichment_ridgeplot",
                    "enrichment_cnetplot", "enrichment_emapplot", "enrichment_do_dotplot",
                    "enrichment_kegg_dotplot", "enrichment_kegg_gsea"):
            targets.append(f"results/figures/{fig}.png")
            targets.append(f"results/figures/{fig}.svg")
        for net in ("enrichment_emap", "enrichment_genemap"):
            for ext in ("graphml", "sif", "cyjs"):
                targets.append(f"results/networks/{net}.{ext}")
            targets.append(f"results/networks/{net}_nodes.csv")
            targets.append(f"results/networks/{net}_edges.csv")
        # Custom gene-set enrichment (optional): only when a GMT or annotation table is set.
        _cs = config.get("gene_sets", {})
        if _cs.get("custom_gene_sets") or _cs.get("functional_annotation_table"):
            targets.append("results/enrichment/custom_ora.csv")
            targets.append("results/enrichment/custom_gsea.csv")
            targets.append("results/enrichment/custom_enrichment_summary.txt")
            targets.append("results/figures/custom_enrichment_dotplot.png")
            targets.append("results/figures/custom_enrichment_dotplot.svg")
    if GSVA_ON:
        targets.append("results/gsva/gsva_scores.csv")
        targets.append("results/figures/gsva_heatmap.png")
        targets.append("results/figures/gsva_heatmap.svg")
    if config.get("gene_sets", {}).get("custom_gene_list") and not DE_RESULTS_MODE:
        targets.append("results/figures/goi_heatmap.png")
        targets.append("results/figures/goi_expression.png")
        targets.append("results/genes_of_interest/goi_report.txt")
    if config.get("ppi", {}).get("enabled", True):
        for ext in ("graphml", "sif", "cyjs"):
            targets.append(f"results/networks/string_ppi.{ext}")
        targets.append("results/networks/string_ppi_nodes.csv")
        targets.append("results/networks/string_ppi_edges.csv")
        targets.append("results/networks/ppi_hub_genes.csv")
        targets.append("results/figures/ppi_network.png")
        targets.append("results/figures/ppi_network.svg")
    return targets


rule all:
    input:
        final_targets(),
