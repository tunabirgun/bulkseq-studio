# BulkSeq Studio workflow: reference-based bulk RNA-seq, STAR -> featureCounts ->
# DESeq2 -> figures, following the bundled protocol. Globals and helper functions
# are defined BEFORE the rule includes so included rules can reference them.
import os
import re
import pandas as pd

configfile: "config/config.yaml"


# ---------------------------------------------------------------------------
# Samples
# ---------------------------------------------------------------------------
samples_df = pd.read_csv(config["input"]["samples"], sep="\t", dtype=str).fillna("")
samples_df = samples_df.set_index("sample_id", drop=False)
SAMPLES = samples_df["sample_id"].tolist()
# Fail fast on an empty sample sheet rather than crashing deep in a rule.
if not SAMPLES:
    raise ValueError(
        f"Sample sheet '{config['input']['samples']}' has no sample rows. "
        "Add at least one sample (Input Data tab) before running."
    )
FIRST_SAMPLE = SAMPLES[0]

# Constrain {sample} to known IDs so paired (..._1.trim) and single (...trim)
# trimmed filenames parse unambiguously.
if SAMPLES:
    wildcard_constraints:
        sample="|".join(re.escape(s) for s in SAMPLES)


def sample_layout(sample):
    layout = str(samples_df.loc[sample, "layout"]).lower() if "layout" in samples_df.columns else "paired"
    return "single" if layout == "single" else "paired"


def is_paired(sample):
    return sample_layout(sample) == "paired"


ALL_PAIRED = all(is_paired(s) for s in SAMPLES) if SAMPLES else True


def raw_fastq(sample, read):
    column = "fastq_1" if read == 1 else "fastq_2"
    value = str(samples_df.loc[sample, column]) if column in samples_df.columns else ""
    return value


# Map each downloadable raw FASTQ target to its ENA URL (built from samples.tsv).
URL_BY_TARGET = {}
for _s in SAMPLES:
    for _url_col, _path_col in (("fastq_1_url", "fastq_1"), ("fastq_2_url", "fastq_2")):
        if _url_col in samples_df.columns and _path_col in samples_df.columns:
            _url = str(samples_df.loc[_s, _url_col]).strip()
            _target = str(samples_df.loc[_s, _path_col]).strip()
            if _url and _target:
                URL_BY_TARGET[_target] = _url


def trimmed_fastqs(sample):
    if is_paired(sample):
        return [f"results/trimmed/{sample}_1.trim.fastq.gz", f"results/trimmed/{sample}_2.trim.fastq.gz"]
    return [f"results/trimmed/{sample}.trim.fastq.gz"]


# ---------------------------------------------------------------------------
# Reference / resources
# ---------------------------------------------------------------------------
REF = config.get("reference", {})
WF = config.get("workflow", {})
INPUT = config.get("input", {})
# Count-matrix mode: the user supplies a counts table, so the pipeline skips
# download/QC/alignment/featureCounts and ingests it into results/counts/counts.txt.
COUNT_MATRIX_MODE = INPUT.get("type") == "count_matrix"
COUNT_MATRIX = INPUT.get("count_matrix")
# Microarray mode: GEO/GSE intensities ingested via GEOquery/affy and analyzed
# with limma; no alignment/reference/counts. limma emits the DESeq2-shaped
# artifacts so figures/enrichment/GOI are shared.
MICROARRAY_MODE = INPUT.get("type") == "microarray"
# Single-end FASTQ is not yet supported on the alignment route (only fastp_pe
# exists); reject it up front with a clear message instead of dead-ending at the
# trim step. Count-matrix / microarray modes have no layout and are unaffected.
if not (COUNT_MATRIX_MODE or MICROARRAY_MODE) and not ALL_PAIRED:
    _se_samples = [s for s in SAMPLES if not is_paired(s)]
    raise ValueError(
        "Single-end FASTQ input is not yet supported (paired-end only). "
        f"Single-end sample(s): {', '.join(_se_samples)}. Provide paired-end "
        "reads, or use the count-matrix or GEO microarray input mode."
    )
GENOME_FA = "references/genome.fa"
ANNOTATION_GTF = "references/annotation.gtf"
STAR_INDEX = "references/star_index"


def rule_threads(name, default=4):
    return int(config.get("rule_threads", {}).get(name, default))


def rule_mem_mb(name, default=8):
    return int(config.get("rule_memory_gb", {}).get(name, default)) * 1000


# ---------------------------------------------------------------------------
# Rule includes (order matters only for readability; globals already defined)
# ---------------------------------------------------------------------------
include: "rules/sra.smk"
include: "rules/reference.smk"
include: "rules/qc.smk"
include: "rules/trimming.smk"
include: "rules/alignment.smk"
include: "rules/quantification.smk"
include: "rules/microarray.smk"
include: "rules/deseq2.smk"
include: "rules/figures.smk"
include: "rules/enrichment.smk"
include: "rules/checks.smk"
include: "rules/reports.smk"
include: "rules/coexpression.smk"


# ---------------------------------------------------------------------------
# Targets
# ---------------------------------------------------------------------------
def final_targets():
    targets = [
        "results/deseq2/deseq2_results.csv",
        "results/export/normalized_expression_matrix.csv",
        "results/export/ranked_genes.rnk",
        "results/figures/sample_correlation_pearson.png",
        "results/figures/sample_correlation_pearson.svg",
        "results/figures/sample_correlation_spearman.png",
        "results/figures/sample_correlation_spearman.svg",
        "results/export/sample_correlation_pearson.csv",
        "results/export/sample_correlation_spearman.csv",
        "results/reports/run_summary.txt",
        "results/reports/timing_summary.txt",
        "results/reports/software_versions.txt",
        "checks/sanity_checks.txt",
    ]
    # Microarray has no counts.txt (intensities, not counts); every other mode does.
    if not MICROARRAY_MODE:
        targets.insert(0, "results/counts/counts.txt")
    if not (COUNT_MATRIX_MODE or MICROARRAY_MODE):
        # MultiQC aggregates FastQC/fastp/STAR — irrelevant without alignment.
        targets.insert(0, "results/qc/multiqc/multiqc_report.html")
    if WF.get("figures", True):
        for fig in ("pca", "sample_distance", "ma_plot", "volcano", "top_deg_heatmap"):
            targets.append(f"results/figures/{fig}.png")
            targets.append(f"results/figures/{fig}.svg")
    if WF.get("enrichment", True):
        targets.append("results/enrichment/enrichment_summary.txt")
        for fig in ("enrichment_dotplot", "enrichment_gsea", "enrichment_ridgeplot",
                    "enrichment_cnetplot", "enrichment_emapplot"):
            targets.append(f"results/figures/{fig}.png")
            targets.append(f"results/figures/{fig}.svg")
    if config.get("gene_sets", {}).get("custom_gene_list"):
        targets.append("results/figures/goi_heatmap.png")
        targets.append("results/figures/goi_expression.png")
        targets.append("results/genes_of_interest/goi_report.txt")
    return targets


rule all:
    input:
        final_targets(),
